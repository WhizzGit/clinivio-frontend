# ─── Backend Service URLs ─────────────────────────────────────────────────────
# Point these to your Render service URLs in production
# e.g. https://mediflow-iam-service.onrender.com

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PATIENT_API_URL=http://localhost:3002
NEXT_PUBLIC_APPOINTMENT_API_URL=http://localhost:3003
NEXT_PUBLIC_BILLING_API_URL=http://localhost:3006

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
# In production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000
